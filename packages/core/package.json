{
    "name": "@softros/agulhao-charts-core",
    "version": "1.0.4",
    "description": "Tipos e tradutor para gerar opcoes ECharts a partir da definicao comum do Agulhao Charts.",
    "homepage": "https://github.com/SOFTROS-SISTEMAS/agulhao-charts",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SOFTROS-SISTEMAS/agulhao-charts.git",
        "directory": "packages/core"
    },
    "peerDependencies": {
        "echarts": ">=5"
    },
    "devDependencies": {
        "echarts": "^5.6.0",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    }
}