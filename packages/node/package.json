    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/SOFTROS-SISTEMAS/agulhao-charts.git",
        "directory": "packages/node"
    },
    "dependencies": {
        "@softros/agulhao-charts-core": "^1.0.0",
        "echarts": "^5.6.0",
        "sharp": "^0.34.2"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    }
}
