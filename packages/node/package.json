{
    "name": "@softros/agulhao-charts-node",
    "version": "1.0.0",
    "description": "Funcoes Node.js para gerar saidas renderizaveis a partir da definicao comum do Agulhao Charts.",
    "homepage": "https://github.com/SOFTROS-SISTEMAS/agulhao-charts",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
