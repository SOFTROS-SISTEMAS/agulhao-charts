    },
    "peerDependencies": {
        "echarts": ">=5",
        "react": ">=18"
    },
    "devDependencies": {
        "@types/react": "^19.1.8",
        "echarts": "^5.6.0",
        "react": "^19.1.0",
        "typescript": "^5.8.3",
        "vitest": "^3.2.4"
    }
