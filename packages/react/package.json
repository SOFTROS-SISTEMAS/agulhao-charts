{
    "name": "@softros-sistemas/agulhao-charts-react",
    "version": "1.0.0",
    "description": "Componente React para renderizar graficos a partir da definicao comum do Agulhao Charts.",
    "homepage": "https://github.com/SOFTROS-SISTEMAS/agulhao-charts",
    "license": "Apache-2.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
